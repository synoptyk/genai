# =============================================================================
# ENVIRONMENT VARIABLES - Gen AI Backend
# Copy this file to .env and fill in your actual values
# =============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
PORT=5003
NODE_ENV=development
PLATFORM_PATH=./platforms/agentetelecom
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Database (MongoDB Atlas)
# ------------------------------------------------------------------------------
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/telecom_db?retryWrites=true&w=majority

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ------------------------------------------------------------------------------
# Email (SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ------------------------------------------------------------------------------
# Cloudinary (File Storage)
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Optional: Cache (Redis) - Not yet implemented
# ------------------------------------------------------------------------------
# CACHE_ENABLED=false
# CACHE_TTL=300
# REDIS_URL=redis://localhost:6379
