# ════════════════════════════════════════════════════════════════════════════
# 🔐 GEN AI - ENVIRONMENT CONFIGURATION TEMPLATE
# ════════════════════════════════════════════════════════════════════════════
#
# ⚠️  IMPORTANTE: Este archivo NO contiene valores reales
# 🚨 NUNCA comitees .env - Solo .env.example en repositorio
#
# Para configurar:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena con valores REALES de tu infraestructura
#   3. NUNCA hagas push de .env
#   4. Usa gestor de secretos para producción
#
# ════════════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════════════════
# 🌍 ENTORNO Y PUERTO
# ════════════════════════════════════════════════════════════════════════════

# Opciones: development, staging, production
NODE_ENV=development

# Puerto donde corre el servidor
PORT=5003

# ════════════════════════════════════════════════════════════════════════════
# 🗃️ BASE DE DATOS - MongoDB
# ════════════════════════════════════════════════════════════════════════════

# ⚠️  CRÍTICO: Esta es la clave más importante
# Formato: mongodb://user:password@host:port/database
# Para producción: Usa MongoDB Atlas con autenticación fuerte
# - Usuario: No usar "admin"
# - Contraseña: Mínimo 32 caracteres, caracteres especiales
# - Conexión: Use IP whitelist y SSL/TLS
#
# Ejemplo (NO USAR):
#   mongodb://myuser:MyPassword123!@34.27.229.165:27017/genai?authSource=admin
#
# Mejor (Usar):
#   mongodb+srv://user:pass@cluster.mongodb.net/genai?retryWrites=true&w=majority

MONGO_URI=mongodb://user:password@localhost:27017/genai_db

# ════════════════════════════════════════════════════════════════════════════
# 🔑 SEGURIDAD Y AUTENTICACIÓN
# ════════════════════════════════════════════════════════════════════════════

# ⚠️  CRÍTICO: Clave para firmar JWT tokens
# - Mínimo: 32 caracteres
# - Debe ser: Aleatorio, seguro, único por ambiente
# - Generar con: openssl rand -base64 32
# - NO usar: "my-secret" o valores predecibles
#
# PRODUCCIÓN: Cambiar cada 30 días

JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-random

# Duración de los tokens (ej: 7d, 24h, 30m)
JWT_EXPIRE=7d

# ════════════════════════════════════════════════════════════════════════════
# 🌐 CORS - URLS PERMITIDAS
# ════════════════════════════════════════════════════════════════════════════

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# URLs adicionales permitidas (separadas por coma)
# ALLOWED_ORIGINS=https://genai.cl,https://app.genai.cl,https://admin.genai.cl

# ════════════════════════════════════════════════════════════════════════════
# 📧 SMTP - CONFIGURACIÓN DE EMAIL
# ════════════════════════════════════════════════════════════════════════════

# Servidor SMTP
SMTP_HOST=smtp.gmail.com

# Puerto (587 para TLS, 465 para SSL)
SMTP_PORT=587

# Email que envía emails
SMTP_EMAIL=your-email@gmail.com

# ⚠️  Usar contraseña de aplicación (NO contraseña de cuenta)
# - Gmail: Generar en https://myaccount.google.com/apppasswords
# - Zoho: Generar en https://zoho.com
SMTP_PASSWORD=your-app-specific-password

# Nombre que aparecerá en los emails
FROM_NAME=Gen AI Platform

# ════════════════════════════════════════════════════════════════════════════
# ☁️ CLOUDINARY - ALMACENAMIENTO DE ARCHIVOS
# ════════════════════════════════════════════════════════════════════════════

# Nombre de la cuenta Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name

# API Key (pública, pero el secret NO)
CLOUDINARY_API_KEY=your-api-key

# ⚠️  SECRET: Nunca exponer este valor
# Generar en: https://cloudinary.com/console
CLOUDINARY_API_SECRET=your-api-secret

# ════════════════════════════════════════════════════════════════════════════
# 🧠 GOOGLE GEMINI AI
# ════════════════════════════════════════════════════════════════════════════

# ⚠️  API Key para Google Gemini
# - Generar en: https://makersuite.google.com/app/apikey
# - Requiere: Cuenta Google Cloud con billing habilitado
# - Costo: Varía según uso (modelo free: 60 requests/minuto)
# - Seguridad: Mantener en secreto, rotary cada 90 días

GEMINI_API_KEY=AIzaSy_your_key_here_keep_secret

# ════════════════════════════════════════════════════════════════════════════
# 🤖 GROQ AI - LLM RÁPIDO Y GRATIS
# ════════════════════════════════════════════════════════════════════════════

# ⚠️  API Key para Groq (Llama 3.3 - modelo gratis)
# - Generar en: https://console.groq.com
# - Límite: 14,400 requests/día
# - Modelo: Llama 3.3 70B
# - Costo: GRATIS (con límite)

GROQ_API_KEY=gsk_your_key_here_keep_secret

# ════════════════════════════════════════════════════════════════════════════
# 📱 GOOGLE MAIL OAUTH2 - INTEGRACIÓN DE EMAIL
# ════════════════════════════════════════════════════════════════════════════

# ⚠️  Credenciales de OAuth de Google
# - Crear en: https://console.cloud.google.com
# - Paso 1: Crear nuevo proyecto
# - Paso 2: Habilitar Gmail API
# - Paso 3: Crear OAuth 2.0 Client ID (Aplicación web)
# - Paso 4: Configurar URIs de redirección

# ID del cliente OAuth
GOOGLE_MAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ⚠️  SECRET de OAuth - MANTENER EN SECRETO
# No commitear nunca
GOOGLE_MAIL_CLIENT_SECRET=your-client-secret-keep-secret

# ════════════════════════════════════════════════════════════════════════════
# 🛠️ CREDENCIALES DE TERCEROS - INTEGRACIÓN TOA
# ════════════════════════════════════════════════════════════════════════════

# URL del sistema TOA (Telefónica)
TOA_URL=https://telefonica-cl.etadirect.com/

# ⚠️  Usuario y contraseña TOA
# - Mantener en secreto
# - Cambiar regularmente
# - NO usar en código

TOA_USER_REAL=your-toa-username
TOA_PASS_REAL=your-toa-password

# ════════════════════════════════════════════════════════════════════════════
# 🚗 GPS SIMPLE - INTEGRACIÓN DE GEOLOCALIZACIÓN
# ════════════════════════════════════════════════════════════════════════════

# URL de GPS Simple
GPS_URL=https://www.gpsimple.cl/track/index.php

# ⚠️  Credenciales GPS
# - Mantener en secreto
# - Email de cuenta

GPS_USER=your-email@company.com
GPS_PASS=your-gps-password

# ════════════════════════════════════════════════════════════════════════════
# 👤 SUPER ADMIN SEED - USUARIO INICIAL
# ════════════════════════════════════════════════════════════════════════════

# Email del superadmin (crear primer usuario)
SEED_ADMIN_EMAIL=admin@company.com

# ⚠️  CONTRASEÑA TEMPORAL - CAMBIAR AL PRIMER LOGIN
# - Generada aleatoriamente al primer inicio
# - Forzar cambio de contraseña en primer acceso

SEED_ADMIN_PASSWORD=GeneratedAtFirstRun_ChangeMe

# Habilitar creación automática de admin al startup
ENABLE_AUTO_SEED=false

# ════════════════════════════════════════════════════════════════════════════
# 📊 LOGGING
# ════════════════════════════════════════════════════════════════════════════

# Nivel de log: error, warn, info, debug
LOG_LEVEL=info

# ════════════════════════════════════════════════════════════════════════════
# 🎯 PLATAFORMA
# ════════════════════════════════════════════════════════════════════════════

# Ruta de la plataforma específica
PLATFORM_PATH=./platforms/agentetelecom

# ════════════════════════════════════════════════════════════════════════════
# ✅ CHECKLIST DE SEGURIDAD ANTES DE PRODUCCIÓN
# ════════════════════════════════════════════════════════════════════════════
#
# 📋 Completar ANTES de usar en producción:
#
# [ ] JWT_SECRET: ¿Es aleatorio y >32 caracteres?
# [ ] MONGO_URI: ¿Usa SSL/TLS y IP whitelist?
# [ ] MONGO_URI: ¿Usuario NO es "admin"?
# [ ] SMTP_PASSWORD: ¿Es contraseña de aplicación, NO de cuenta?
# [ ] Todas las claves API: ¿Son de producción?
# [ ] NODE_ENV: ¿Es "production"?
# [ ] Archivo .env: ¿NO está en git?
# [ ] .env.example: ¿Solo contiene valores dummy?
# [ ] CORS: ¿Está configurado solo para dominios válidos?
# [ ] Rate limiting: ¿Habilitado?
# [ ] Helmet security: ¿Habilitado?
# [ ] Logs: ¿No contienen información sensible?
#
# ════════════════════════════════════════════════════════════════════════════

