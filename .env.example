# ================================
# Gen AI - Environment Template
# Copy to .env and adjust values
# ================================

# Core
NODE_ENV=production
PORT=5003
PLATFORM_PATH=./platforms/agentetelecom

# URLs
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5003

# Database
# Docker local default:
MONGO_URI=mongodb://mongo:27017/genai_db
# Atlas example:
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/genai_db?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRE=7d

# SMTP (optional but recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Logging
LOG_LEVEL=info

# Allowed origins (optional, comma-separated)
# ALLOWED_ORIGINS=http://localhost:3000,https://genai.cl
